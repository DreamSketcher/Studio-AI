+            assert list(outdir.iterdir()) == []
+
+    def test_available_models_reflect_diffusers_presence(self, app):
+        import ai_studio_core.ui.controllers.image_controller as ic
+        ctrl = ic.ImageController()
+        models = ctrl.available_models()
